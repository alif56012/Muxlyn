{
  "name": "@muxlyn/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun run src/data/migrate.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.0.0",
    "@muxlyn/shared": "workspace:*",
    "better-auth": "^1.0.0",
    "drizzle-orm": "^0.36.0",
    "elysia": "^1.0.0",
    "i18next": "^24.0.0",
    "kysely": "^0.29.2",
    "pg": "^8.22.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "tsyringe": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.0"
  }
